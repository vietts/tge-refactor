# Copy to .env and fill in — NEVER commit .env
# For Cloudflare Pages, set these in: Pages > Settings > Environment variables

# Brevo (server-side, used by functions/api/subscribe.ts)
BREVO_API_KEY=xkeysib-...           # server-side only
BREVO_LIST_ID=123                    # master TGE waitlist list id
BREVO_ATTR_NAME=EVENT_INTEREST       # optional, defaults to EVENT_INTEREST

# Meta Pixel + Conversions API
PUBLIC_META_PIXEL_ID=                # exposed to the browser (PUBLIC_ prefix)
META_PIXEL_ID=                       # server-side, same value as PUBLIC_META_PIXEL_ID
META_CAPI_TOKEN=EAA...               # server-side CAPI access token
META_TEST_EVENT_CODE=                # optional, set during Events Manager test then remove
