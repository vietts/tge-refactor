---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FactsBar from '../components/FactsBar.astro';
import BrevoForm from '../components/BrevoForm.astro';
import DocumentaryEmbed from '../components/DocumentaryEmbed.astro';
import PhilosophyQuote from '../components/PhilosophyQuote.astro';
import RegistrationCountdown from '../components/RegistrationCountdown.astro';
import PlacesBento from '../components/PlacesBento.astro';
import PhotoSplit from '../components/PhotoSplit.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import WhatsIncluded from '../components/WhatsIncluded.astro';
import Testimonials from '../components/Testimonials.astro';
import Credo from '../components/Credo.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TrustStrip from '../components/TrustStrip.astro';
import StickyCTA from '../components/StickyCTA.astro';

type EventFontKey = 'germania' | 'questrial' | 'tuscany';
type IconKey = 'calendar' | 'pin' | 'loop' | 'road' | 'clock' | 'mountain';

interface Fact { icon: IconKey; label: string; value: string; sub?: string }
interface Place { name: string; description: string; size?: 'sm' | 'md' | 'lg'; image?: string }
interface Testi { quote: string; author: string; event?: string }
interface FaqItem { q: string; a: string }
interface PhotoSplitSide { title: string; body: string; caption: string; image?: string }
interface PhotoBreakItem { caption?: string; image?: string }
type SectionKey =
  | 'facts'
  | 'signupTop'
  | 'countdown'
  | 'philosophy'
  | 'documentary'
  | 'places'
  | 'mdxBody'
  | 'photoSplitDay'
  | 'included'
  | 'photoBreakIncluded'
  | 'testimonials'
  | 'photoBreakTestimonials'
  | 'credo'
  | 'photoSplitQuiet'
  | 'signupBottom'
  | 'photoBreakFaq'
  | 'faq';

const DEFAULT_SECTION_ORDER: SectionKey[] = [
  'facts',
  'signupTop',
  'countdown',
  'philosophy',
  'documentary',
  'places',
  'mdxBody',
  'photoSplitDay',
  'included',
  'photoBreakIncluded',
  'testimonials',
  'photoBreakTestimonials',
  'credo',
  'photoSplitQuiet',
  'signupBottom',
  'photoBreakFaq',
  'faq',
];

interface PageEvent {
  slug: 'slovenia' | 'germany' | 'tuscany';
  name: string;
  dateLabel: string;
  tagline?: string;
  quote: string;
  statusLabel: string;
  subBrandColor: string;
  distanceKm: number;
  brevoSegment: 'slovenia' | 'germany' | 'tuscany';
  philosophyQuote?: string;
  philosophyImage?: string;
  registrationOpens?: {
    date: string;
    kicker?: string;
    title: string;
    body?: string;
    ctaLabel?: string;
    ctaHref?: string;
    openLabel?: string;
  };
  heroImage?: string;
  places?: Place[];
  included?: string[];
  testimonials?: Testi[];
  faq?: FaqItem[];
  photoSplits?: { day: PhotoSplitSide; quiet: PhotoSplitSide };
  photoBreaks?: { included?: PhotoBreakItem; testimonials?: PhotoBreakItem; faq?: PhotoBreakItem };
  sectionOrder?: SectionKey[];
}
interface TrustData {
  label: string;
  partners: Array<{ name: string; logo: string; isMain?: boolean }>;
}

interface Props {
  event: PageEvent;
  trust: TrustData;
  docYoutubeId: string;
  eventNumberLabel: string;          // e.g. "Event 01"
  titleFont: EventFontKey;           // which extra font for all H2
  waitlistCtaLabel: string;          // "Join the waitlist" / "Join 2027 waitlist"
  signupBenefits: string[];
  factsBar: Fact[];
  credoIntro: string[];
  credoPillars: Array<{ title: string; body: string }>;
  photoBreakCaptions?: { included?: string; testimonials?: string; faq?: string };
  photoSplits?: { dayTitle: string; dayBody: string; dayCaption: string; quietTitle: string; quietBody: string; quietCaption: string };
  docLabel?: string;
  docTitle?: string;
  docSubtitle?: string;
}

const {
  event,
  trust,
  docYoutubeId,
  eventNumberLabel,
  titleFont,
  waitlistCtaLabel,
  signupBenefits,
  factsBar,
  credoIntro,
  credoPillars,
  photoBreakCaptions = {},
  photoSplits,
  docLabel = 'From the road · 2025',
  docTitle,
  docSubtitle,
} = Astro.props;

const accent = event.subBrandColor;

// Prefer frontmatter photoSplits (CMS-editable new shape { day, quiet }); fall back to legacy prop shape.
const splits = event.photoSplits
  ? {
      dayTitle: event.photoSplits.day.title,
      dayBody: event.photoSplits.day.body,
      dayCaption: event.photoSplits.day.caption,
      dayImage: event.photoSplits.day.image,
      quietTitle: event.photoSplits.quiet.title,
      quietBody: event.photoSplits.quiet.body,
      quietCaption: event.photoSplits.quiet.caption,
      quietImage: event.photoSplits.quiet.image,
    }
  : photoSplits
  ? { ...photoSplits, dayImage: undefined, quietImage: undefined }
  : null;

const breaks = {
  included: event.photoBreaks?.included ?? { caption: photoBreakCaptions.included },
  testimonials: event.photoBreaks?.testimonials ?? { caption: photoBreakCaptions.testimonials },
  faq: event.photoBreaks?.faq ?? { caption: photoBreakCaptions.faq },
};

const fontClassMap: Record<EventFontKey, string> = {
  germania: 'font-event-germania',
  questrial: 'font-event-questrial',
  tuscany: 'font-event-tuscany',
};
const fontClass = fontClassMap[titleFont];

// Resolve section order (editable from Pages CMS via frontmatter `sectionOrder`).
// Unknown keys are ignored; missing keys fall back to the tail of the default order.
const requested = event.sectionOrder ?? DEFAULT_SECTION_ORDER;
const seen = new Set<SectionKey>();
const sectionOrder: SectionKey[] = [];
for (const k of requested) {
  if (DEFAULT_SECTION_ORDER.includes(k as SectionKey) && !seen.has(k as SectionKey)) {
    sectionOrder.push(k as SectionKey);
    seen.add(k as SectionKey);
  }
}
for (const k of DEFAULT_SECTION_ORDER) {
  if (!seen.has(k)) sectionOrder.push(k);
}
---
<BaseLayout
  title={`The Grand Escape — ${event.name} · ${event.dateLabel}`}
  description={`${event.tagline ?? event.quote} ${event.distanceKm}km of bikepacking. Limited spots.`}
  theme="dark"
  dataEvent={event.slug}
>
  <div class={`event-page ${fontClass}`}>
    <Hero
      variant="event"
      kicker={`The Grand Escape · ${eventNumberLabel}`}
      serif={event.tagline ?? event.quote}
      huge={event.name}
      dateLabel={event.dateLabel}
      statusLabel={event.statusLabel}
      ctaLabel={waitlistCtaLabel}
      ctaHref="#signup"
      subBrandColor={accent}
      image={event.heroImage}
    >
      <slot name="mascot" slot="mascot" />
    </Hero>

    {sectionOrder.map((key) => (
      <>
        {key === 'facts' && <FactsBar accentColor={accent} facts={factsBar} />}

        {key === 'signupTop' && (
          <BrevoForm
            variant="event"
            eventSegment={event.brevoSegment}
            kicker="Waitlist · Limited spots"
            title="Be first in line."
            body="Leave your email and we'll send you:"
            benefits={signupBenefits}
            ctaLabel={waitlistCtaLabel}
            legal="Limited spots · Unsubscribe anytime · No spam, ever"
            accentColor={accent}
            anchorId="signup"
          />
        )}

        {key === 'countdown' && event.registrationOpens && (
          <RegistrationCountdown
            targetIso={event.registrationOpens.date}
            kicker={event.registrationOpens.kicker}
            title={event.registrationOpens.title}
            body={event.registrationOpens.body}
            ctaLabel={event.registrationOpens.ctaLabel ?? waitlistCtaLabel}
            ctaHref={event.registrationOpens.ctaHref ?? '#signup'}
            openLabel={event.registrationOpens.openLabel}
            accentColor={accent}
          />
        )}

        {key === 'philosophy' && event.philosophyQuote && (
          <PhilosophyQuote quote={event.philosophyQuote} image={event.philosophyImage} accentColor={accent} />
        )}

        {key === 'documentary' && (
          <DocumentaryEmbed
            youtubeId={docYoutubeId}
            label={docLabel}
            title={docTitle ?? `The Grand Escape — ${event.name}`}
            subtitle={docSubtitle ?? "Ninety minutes with the riders of last year's edition. Pace, scenery, and the reason we don't call it a race."}
          />
        )}

        {key === 'places' && event.places && event.places.length > 0 && (
          <PlacesBento
            kicker="Places you'll cross"
            title={`A ride through ${event.places.length} landscapes`}
            subtitle="The loop is curated so every day brings a different world."
            places={event.places}
            accentColor={accent}
          />
        )}

        {key === 'mdxBody' && (
          <div class="mdx-copy">
            <slot name="mdx-copy" />
          </div>
        )}

        {key === 'photoSplitDay' && splits && (
          <PhotoSplit
            kicker="A day on the road"
            title={splits.dayTitle}
            body={splits.dayBody}
            imageCaption={splits.dayCaption}
            image={splits.dayImage}
            accentColor={accent}
          />
        )}

        {key === 'included' && event.included && event.included.length > 0 && (
          <WhatsIncluded
            kicker="What's included"
            title="Everything you need, nothing you don't"
            items={event.included}
            accentColor={accent}
          />
        )}

        {key === 'photoBreakIncluded' && (
          <PhotoBreak
            height="md"
            caption={breaks.included.caption ?? 'On the road'}
            image={breaks.included.image}
            accentColor={accent}
          />
        )}

        {key === 'testimonials' && event.testimonials && event.testimonials.length > 0 && (
          <Testimonials
            kicker="Riders on the road"
            title="What they remember"
            items={event.testimonials}
          />
        )}

        {key === 'photoBreakTestimonials' && (
          <PhotoBreak
            height="md"
            caption={breaks.testimonials.caption ?? 'Early light'}
            image={breaks.testimonials.image}
            accentColor={accent}
          />
        )}

        {key === 'credo' && (
          <Credo
            kicker="What you'll find at The Grand Escape"
            title="Cycling, the way you first fell for it"
            intro={credoIntro}
            pillars={credoPillars}
            authority={{
              kicker: 'Organized by',
              body: "Part of Bike Adventure Series — Europe's first no-race bikepacking series. 20,000+ cyclists across Tuscany Trail (since 2014), NorthCape4000, Unpaved Roads and The Grand Escape.",
              logo: '/brand/bas-logo.webp',
              logoAlt: 'Bike Adventure Series',
              href: 'https://www.bikeadventureseries.com',
            }}
            accentColor={accent}
          />
        )}

        {key === 'photoSplitQuiet' && splits && (
          <PhotoSplit
            reverse
            kicker="The quiet between climbs"
            title={splits.quietTitle}
            body={splits.quietBody}
            imageCaption={splits.quietCaption}
            image={splits.quietImage}
            accentColor={accent}
          />
        )}

        {key === 'signupBottom' && (
          <BrevoForm
            variant="event"
            eventSegment={event.brevoSegment}
            kicker="Still on the fence?"
            title="Lock in your spot while you decide."
            body="Leaving your email costs nothing and gives you:"
            benefits={signupBenefits}
            ctaLabel={waitlistCtaLabel}
            legal="Limited spots · Unsubscribe anytime · No spam, ever"
            accentColor={accent}
            anchorId="signup-bottom"
          />
        )}

        {key === 'photoBreakFaq' && (
          <PhotoBreak
            height="sm"
            caption={breaks.faq.caption ?? 'See you on the road'}
            image={breaks.faq.image}
            accentColor={accent}
          />
        )}

        {key === 'faq' && event.faq && event.faq.length > 0 && (
          <FAQAccordion
            kicker="FAQ"
            title="Before you sign up"
            items={event.faq}
            accentColor={accent}
          />
        )}
      </>
    ))}

    <TrustStrip label={trust.label} partners={trust.partners} />
    <StickyCTA label={waitlistCtaLabel} href="#signup" accentColor={accent} />
  </div>
</BaseLayout>

<style is:global>
  /* Event pages: apply extra display font to ALL section titles consistently.
     The page wraps everything in a class; title selectors cascade within it. */
  .font-event-germania .hero.event .hero-event-name,
  .font-event-germania .signup-title,
  .font-event-germania .places-title,
  .font-event-germania .incl-title,
  .font-event-germania .testimonials-title,
  .font-event-germania .credo-title,
  .font-event-germania .faq-title,
  .font-event-germania .event-copy h2 {
    font-family: var(--font-extra-germany), var(--font-display) !important;
    font-weight: 400 !important;
    letter-spacing: 0.005em !important;
    text-transform: uppercase;
    line-height: 0.95;
  }

  .font-event-questrial .hero.event .hero-event-name,
  .font-event-questrial .signup-title,
  .font-event-questrial .places-title,
  .font-event-questrial .incl-title,
  .font-event-questrial .testimonials-title,
  .font-event-questrial .credo-title,
  .font-event-questrial .faq-title,
  .font-event-questrial .event-copy h2 {
    font-family: var(--font-extra-slovenia), var(--font-display) !important;
    font-weight: 400 !important;
    letter-spacing: 0.01em !important;
    text-transform: uppercase;
    line-height: 0.95;
  }

  .font-event-tuscany .hero.event .hero-event-name,
  .font-event-tuscany .signup-title,
  .font-event-tuscany .places-title,
  .font-event-tuscany .incl-title,
  .font-event-tuscany .testimonials-title,
  .font-event-tuscany .credo-title,
  .font-event-tuscany .faq-title,
  .font-event-tuscany .event-copy h2 {
    font-family: var(--font-extra-tuscany), var(--font-display) !important;
    font-weight: 400 !important;
    letter-spacing: -0.005em !important;
    text-transform: none;
    line-height: 0.98;
  }
  .font-event-tuscany .hero.event .hero-event-name { font-style: italic; }

  /* Pretzel / Boar inline SVG mascots use currentColor via inline style; shared positioning */
  .event-mascot {
    position: absolute;
    top: 5.5rem;
    right: 1rem;
    z-index: 3;
    width: 100px; height: 100px;
    opacity: 0.94;
    filter: drop-shadow(0 4px 16px rgba(0,0,0,0.3));
    transform: rotate(-6deg);
    transform-origin: center;
    pointer-events: none;
    max-width: 30vw;
    max-height: 30vw;
  }
  .event-mascot-img {
    filter: brightness(0) invert(1) drop-shadow(0 4px 16px rgba(0,0,0,0.35));
    object-fit: contain;
    width: 100%; height: 100%;
  }

  @media (min-width: 720px) {
    .event-mascot { top: 7rem; right: 4rem; width: 200px; height: 200px; max-width: none; max-height: none; }
  }
  @media (min-width: 1100px) {
    .event-mascot { right: 8rem; width: 240px; height: 240px; }
  }
</style>
