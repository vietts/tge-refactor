---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RegistrationCountdown from '../components/RegistrationCountdown.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';
import { hasValidDate } from '../lib/date';

const entry = await getEntry('registrations', '2026');
if (!entry) throw new Error('Registrations entry 2026 not found');
const data = entry.data;
---
<BaseLayout
  title="Register for The Grand Escape 2026"
  description="How to register for The Grand Escape 2026. Early Bird from €137. Limited spots, 3 events across Italy/Slovenia, Germany/Austria and Tuscany. Register via Bike Adventure Series."
  theme="light"
>
  {hasValidDate(data.registrationOpenIso) && (
    <RegistrationCountdown
      targetIso={data.registrationOpenIso}
      kicker={data.countdown.kicker}
      title={data.countdown.title}
      body={data.countdown.body}
      ctaLabel={data.countdown.ctaLabel}
      ctaHref={data.basAccountUrl}
      openLabel={data.countdown.openLabel}
      openCtaLabel={data.countdown.openCtaLabel}
      openHref={data.basRegisterUrl}
      accentColor={data.countdown.accentColor}
      first={true}
    />
  )}

  <section class="reg-hero">
    <div class="container-narrow">
      <div class="kicker reg-kicker">{data.hero.kicker}</div>
      <h1 class="reg-title t-brand">{data.hero.title}</h1>
      <p class="reg-lead">{data.hero.lead}</p>
      {data.hero.contactHtml && (
        <p class="reg-contact" set:html={data.hero.contactHtml} />
      )}
    </div>
  </section>

  <section class="reg-account">
    <div class="container-narrow">
      <div class="kicker">{data.account.kicker}</div>
      <h2 class="t-brand">{data.account.title}</h2>
      {data.account.bodyParagraphs.map((p) => <p>{p}</p>)}
      <div class="reg-actions">
        <a class="cta-pill cta-primary" href={data.basAccountUrl} target="_blank" rel="noopener">
          {data.account.ctaAccountLabel} <Icon name="external" size={14} />
        </a>
        <a class="cta-pill cta-outline" href={data.basRegisterUrl} target="_blank" rel="noopener">
          {data.account.ctaRegisterLabel} <Icon name="arrow" size={14} />
        </a>
      </div>
      {data.account.supportHtml && (
        <p class="reg-support" set:html={data.account.supportHtml} />
      )}
    </div>
  </section>

  <section class="reg-benefits">
    <div class="container-narrow">
      <div class="kicker">{data.benefits.kicker}</div>
      <h2 class="t-brand">{data.benefits.title}</h2>
      <ul class="benefits-grid">
        {data.benefits.items.map((label) => (
          <li>
            <span class="bcheck" aria-hidden="true">✓</span>
            <span>{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="reg-pricing">
    <div class="container-narrow">
      <div class="kicker">{data.pricing.kicker}</div>
      <h2 class="t-brand">{data.pricing.title}</h2>
      <div class="price-grid">
        {data.pricing.cards.map((c) => (
          <article class:list={['price-card', { 'price-card-regular': c.highlighted }]}>
            <div class="price-label">{c.label}</div>
            <div class="price-value">{c.value}</div>
            <div class="price-dates">{c.dates}</div>
            {c.note && <p class="price-note">{c.note}</p>}
          </article>
        ))}
      </div>
      {data.pricing.rulesHtml && (
        <p class="price-rules" set:html={data.pricing.rulesHtml} />
      )}
    </div>
  </section>

  <div id="faq">
    <FAQAccordion
      kicker={data.faq.kicker}
      title={data.faq.title}
      items={data.faq.items}
      accentColor={data.faq.accentColor}
    />
  </div>

  <section class="reg-final">
    <div class="container-narrow">
      <h2 class="t-brand">{data.final.title}</h2>
      {data.final.body && <p>{data.final.body}</p>}
      <a class="cta-pill cta-primary reg-final-cta" href={data.basRegisterUrl} target="_blank" rel="noopener">
        {data.final.ctaLabel} <Icon name="external" size={14} />
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .reg-hero {
    padding: var(--sp-9) 0 var(--sp-7);
  }
  .reg-kicker { color: var(--fern); margin-bottom: 1rem; }
  .reg-title {
    font-size: var(--fs-3xl);
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }
  .reg-lead {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--espresso);
    max-width: 62ch;
  }
  .reg-contact {
    margin-top: 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--espresso);
    opacity: 0.85;
  }
  .reg-contact :global(a), .reg-account p :global(a), .reg-support :global(a), .price-rules :global(a) {
    color: var(--red-wine);
    border-bottom: 1px solid var(--red-wine);
  }

  .reg-account {
    padding: var(--sp-8) 0;
    background: rgba(107, 68, 35, 0.06);
    border-top: 1px solid rgba(107, 68, 35, 0.14);
    border-bottom: 1px solid rgba(107, 68, 35, 0.14);
  }
  .reg-account .kicker { color: var(--red-wine); margin-bottom: 0.75rem; }
  .reg-account h2 {
    font-size: var(--fs-2xl);
    line-height: 0.95;
    margin-bottom: 1rem;
  }
  .reg-account p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--espresso);
    margin-bottom: 0.75rem;
    max-width: 62ch;
  }
  .reg-actions {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    margin: 1.5rem 0 1rem;
  }
  .reg-support { font-size: 0.92rem; opacity: 0.8; }

  .reg-benefits { padding: var(--sp-8) 0; }
  .reg-benefits .kicker { color: var(--fern); margin-bottom: 0.75rem; }
  .reg-benefits h2 {
    font-size: var(--fs-2xl);
    line-height: 0.95;
    margin-bottom: 2rem;
  }
  .benefits-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem 1.5rem;
  }
  .benefits-grid li {
    display: flex; gap: 0.65rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    color: var(--espresso);
  }
  .bcheck {
    color: var(--fern);
    font-weight: 800;
    flex-shrink: 0;
  }

  .reg-pricing { padding: var(--sp-8) 0; background: var(--espresso); color: var(--paper-1); }
  .reg-pricing .kicker { color: var(--caramel); margin-bottom: 0.75rem; }
  .reg-pricing h2 {
    color: var(--paper-1);
    font-size: var(--fs-2xl);
    line-height: 0.95;
    margin-bottom: 2rem;
  }
  .price-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .price-card {
    padding: 1.75rem 1.5rem;
    background: rgba(243, 236, 224, 0.06);
    border: 1px solid rgba(243, 236, 224, 0.15);
    border-radius: 10px;
  }
  .price-card-regular {
    border-color: var(--caramel);
    box-shadow: 0 0 0 1px var(--caramel);
  }
  .price-label {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--caramel);
    margin-bottom: 0.5rem;
  }
  .price-value {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--fs-3xl);
    line-height: 1;
    color: var(--paper-1);
    letter-spacing: -0.02em;
  }
  .price-dates {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--paper-1);
    opacity: 0.75;
    margin-top: 0.4rem;
  }
  .price-note {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--paper-1);
    opacity: 0.65;
    margin-top: 0.85rem;
  }
  .price-rules {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--paper-1);
    opacity: 0.85;
  }
  .price-rules :global(a) {
    color: var(--caramel);
    border-bottom-color: var(--caramel);
  }

  .reg-final {
    padding: var(--sp-9) 0;
    text-align: center;
  }
  .reg-final h2 {
    font-size: var(--fs-2xl);
    margin-bottom: 1rem;
  }
  .reg-final p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--espresso);
    margin-bottom: 1.5rem;
  }
  .reg-final-cta { font-size: 0.95rem; }

  @media (min-width: 720px) {
    .reg-title { font-size: var(--fs-4xl); }
    .benefits-grid { grid-template-columns: 1fr 1fr; }
    .price-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
