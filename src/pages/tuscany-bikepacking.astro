---
import { getEntry, render } from 'astro:content';
import EventLayout from '../layouts/EventLayout.astro';
import { credoIntro, credoPillars } from '../lib/event-defaults';

const event = await getEntry('events', 'tuscany');
if (!event) throw new Error('Event tuscany not found');
const { Content } = await render(event);
const data = event.data;

const hub = (await getEntry('hub', 'main'))!.data;
---
<EventLayout
  event={data}
  trust={hub.trust}
  eventSignupTop={hub.eventSignupTop}
  eventSignupBottom={hub.eventSignupBottom}
  docYoutubeId={data.youtubeId ?? hub.documentary.youtubeId}
  eventNumberLabel={data.eventNumberLabel}
  titleFont={data.titleFont}
  waitlistCtaLabel={data.waitlistCtaLabel}
  factsBar={data.factsBar}
  credoIntro={credoIntro}
  credoPillars={credoPillars}
>
  <img
    slot="mascot"
    src="/brand/tuscany-mascot.svg"
    alt="Boar — Tuscany mascot"
    class="event-mascot event-mascot-img"
    loading="lazy"
  />

  <section slot="mdx-copy" class="event-copy-wrap">
    <div class="container-narrow sr">
      <div class="event-copy">
        <Content />
      </div>
    </div>
  </section>
</EventLayout>

<style is:global>
  .event-copy-wrap { padding: var(--sp-8) 0; position: relative; }
  .event-copy h2 { font-family: var(--font-extra-tuscany), var(--font-display); font-style: italic; font-weight: 400; font-size: var(--fs-3xl); line-height: 0.98; color: var(--red-wine); margin: 0.5rem 0 1.25rem; letter-spacing: -0.005em; text-transform: none; }
  .event-copy h3 { font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--red-wine); margin: 2rem 0 0.75rem; }
  .event-copy p { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.7; margin-bottom: 1rem; color: var(--espresso); }
  .event-copy strong { color: var(--red-wine); font-weight: 700; }
  .event-copy em { font-family: var(--font-extra-tuscany), Georgia, serif; font-size: 1.15em; }
  .event-copy ul { padding-left: 1.2rem; margin: 0.5rem 0 1rem; }
  .event-copy li { font-family: var(--font-body); margin-bottom: 0.4rem; line-height: 1.55; color: var(--espresso); }
</style>
