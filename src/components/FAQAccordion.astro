---
interface Item { q: string; a: string }
interface Props {
  kicker: string;
  title: string;
  items: Item[];
  accentColor?: string;
}
const { kicker, title, items, accentColor } = Astro.props;
---
<section class="faq" style={accentColor ? `--accent:${accentColor}` : undefined}>
  <div class="container-narrow">
    <header class="faq-head sr">
      <div class="kicker">{kicker}</div>
      <h2 class="faq-title display">{title}</h2>
    </header>

    <div class="faq-list">
      {items.map((it) => (
        <details class="faq-item">
          <summary class="faq-q">
            <span>{it.q}</span>
            <span class="chev" aria-hidden="true">+</span>
          </summary>
          <div class="faq-a">{it.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { padding: var(--sp-8) 0; position: relative; }
  .faq-head { margin-bottom: 2rem; text-align: center; }
  .faq-head .kicker { color: var(--accent, var(--fern)); margin-bottom: 0.75rem; }
  .faq-title { font-size: var(--fs-3xl); line-height: 0.95; color: var(--red-wine); }

  .faq-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .faq-item {
    border-top: 1px solid rgba(107,68,35,0.18);
    padding: 0.25rem 0;
  }
  .faq-item:last-child { border-bottom: 1px solid rgba(107,68,35,0.18); }

  .faq-q {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0.25rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.3;
    color: var(--red-wine);
    list-style: none;
    transition: color 140ms;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q:hover { color: var(--accent, var(--red-wine)); }
  .chev {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem; line-height: 1;
    color: var(--accent, var(--fern));
    transition: transform 180ms var(--ease-out);
    flex-shrink: 0;
  }
  .faq-item[open] .chev { transform: rotate(45deg); }

  .faq-a {
    padding: 0 0.25rem 1.2rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--espresso);
    max-width: 60ch;
  }

  @media (min-width: 640px) {
    .faq-q { font-size: 1.15rem; padding: 1.15rem 0.25rem; }
  }
</style>
