---
import Icon from './Icon.astro';

interface Props {
  variant?: 'manifesto' | 'event';
  kicker?: string;
  serif?: string;
  huge: string;
  subtitle?: string;
  ctaLabel: string;
  ctaHref: string;
  videoSrc?: string;
  posterSrc?: string;
  subBrandColor?: string;
  dateLabel?: string;
  statusLabel?: string;
  image?: string;
}

const {
  variant = 'manifesto',
  kicker,
  serif,
  huge,
  subtitle,
  ctaLabel,
  ctaHref,
  videoSrc,
  posterSrc,
  subBrandColor,
  dateLabel,
  statusLabel,
  image,
} = Astro.props;
const heroStyle = [
  subBrandColor ? `--accent:${subBrandColor}` : '',
  image ? `background-image:url('${image}');background-size:cover;background-position:center;` : '',
].filter(Boolean).join(';');
---
<section class:list={['hero', variant]} style={heroStyle || undefined}>
  {videoSrc && (
    <video class="hero-video" autoplay muted loop playsinline poster={posterSrc} aria-hidden="true">
      <source src={videoSrc} type="video/webm" />
    </video>
  )}
  <div class="hero-overlay" aria-hidden="true"></div>

  <slot name="mascot" />

  <div class="hero-content sr">
    {variant === 'event' && (statusLabel || dateLabel) && (
      <div class="hero-ticker">
        {statusLabel && <span class="ticker-status"><span class="dot" aria-hidden="true">●</span> {statusLabel}</span>}
        {statusLabel && dateLabel && <span class="ticker-sep" aria-hidden="true">—</span>}
        {dateLabel && <span class="ticker-date">{dateLabel}</span>}
      </div>
    )}

    {kicker && <div class="kicker hero-kicker">{kicker}</div>}

    {variant === 'manifesto' && (
      <>
        {serif && <p class="hero-serif serif">{serif}</p>}
        <h1 class="hero-huge display">{huge}</h1>
      </>
    )}

    {variant === 'event' && (
      <>
        <h1 class="hero-event-name display">{huge.replace(/\//g, '/\u200B')}</h1>
        {serif && <p class="hero-quote serif">{serif}</p>}
      </>
    )}

    {subtitle && <p class="hero-subtitle">{subtitle}</p>}
    <a class="cta-pill cta-on-dark hero-cta" href={ctaHref}>
      {ctaLabel} <Icon name="arrow" size={14} />
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex; align-items: flex-end;
    background: var(--espresso);
    color: var(--paper-1);
    overflow: hidden;
    padding: 0 var(--sp-5) var(--sp-9);
    padding-top: 5rem;
  }
  .hero-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center center;
    z-index: 1;
  }
  .hero-overlay {
    position: absolute; inset: 0; z-index: 2;
    background:
      linear-gradient(180deg, rgba(44,31,21,0.30) 0%, rgba(44,31,21,0.55) 55%, rgba(44,31,21,0.90) 100%);
  }
  .hero-content { position: relative; z-index: 3; max-width: 720px; width: 100%; margin: 0 auto; }
  .hero-kicker { color: var(--caramel); margin-bottom: 1rem; }
  .hero-serif { font-family: var(--font-body); font-size: var(--fs-lg); line-height: 1.4; margin-bottom: 1rem; color: rgba(243,236,224,0.9); }
  .hero-huge { font-size: var(--fs-4xl); line-height: 0.95; color: var(--paper-1); text-transform: none; letter-spacing: -0.02em; max-width: 18ch; }

  .hero.event { align-items: flex-end; }
  .hero-event-name {
    font-size: clamp(44px, 9vw + 12px, 128px);
    line-height: 0.92;
    color: var(--accent, var(--paper-1));
    max-width: 100%;
    overflow-wrap: break-word;
    hyphens: auto;
    text-wrap: balance;
  }
  .hero-quote { font-family: var(--font-body); font-size: var(--fs-lg); line-height: 1.4; margin: 1rem 0; max-width: 22ch; opacity: 0.92; }

  /* Ticker: status + date in one editorial line above the kicker */
  .hero-ticker {
    display: flex; align-items: center; flex-wrap: wrap;
    gap: 0.6rem;
    font-family: var(--font-display); font-weight: 700;
    font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--accent, var(--caramel));
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(250,191,128,0.3);
  }
  .ticker-status .dot {
    display: inline-block;
    font-size: 0.75em;
    animation: pulse 1.8s ease-in-out infinite;
  }
  .ticker-sep { opacity: 0.5; letter-spacing: 0; }
  .ticker-date { color: rgba(255,255,255,0.78); }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-status .dot { animation: none; }
  }

  .hero-subtitle { max-width: 40ch; margin-top: 1rem; opacity: 0.9; line-height: 1.55; }
  .hero-cta { margin-top: 1.75rem; }

  @media (max-width: 520px) {
    .hero { padding-bottom: var(--sp-7); padding-top: 4.5rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video { display: none; }
  }
</style>
