---
interface Props {
  youtubeId: string;
  label: string;
  title: string;
  subtitle: string;
}
const { youtubeId, label, title, subtitle } = Astro.props;
---
<section class="doc">
  <div class="container-narrow sr">
    <div class="kicker doc-label">● {label}</div>
    <h2 class="doc-title display">{title}</h2>
    <p class="doc-sub">{subtitle}</p>

    <button class="yt-thumb" aria-label={`Play: ${title}`} data-yt-id={youtubeId}>
      <img
        src={`https://i.ytimg.com/vi/${youtubeId}/maxresdefault.jpg`}
        alt=""
        loading="lazy"
        width="1280" height="720"
      />
      <span class="yt-play" aria-hidden="true"></span>
    </button>
  </div>
</section>

<style>
  .doc { background: var(--espresso); color: var(--paper-1); padding: var(--sp-8) 0; position: relative; }
  .doc-label { color: var(--caramel); margin-bottom: 0.6rem; }
  .doc-title { font-size: var(--fs-3xl); line-height: 0.95; color: var(--paper-1); margin-bottom: 0.8rem; }
  .doc-sub { font-family: var(--font-body); opacity: 0.78; max-width: 48ch; margin-bottom: 1.5rem; line-height: 1.6; color: rgba(243,236,224,0.85); }

  .yt-thumb {
    position: relative; display: block; width: 100%;
    aspect-ratio: 16/9; border-radius: 10px; overflow: hidden;
    background: #000;
  }
  .yt-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.75; transition: opacity 200ms; }
  .yt-thumb:hover img { opacity: 0.9; }
  .yt-play {
    position: absolute; inset: 0; margin: auto; width: 72px; height: 72px;
    border-radius: 50%; background: rgba(255,255,255,0.95);
    display: flex; align-items: center; justify-content: center;
  }
  .yt-play::after {
    content: ''; border-left: 22px solid var(--red-wine);
    border-top: 14px solid transparent; border-bottom: 14px solid transparent;
    margin-left: 6px;
  }
</style>

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.yt-thumb')) {
    btn.addEventListener('click', () => {
      const id = btn.dataset.ytId;
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
      iframe.allow = 'autoplay; fullscreen; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.loading = 'lazy';
      iframe.style.cssText = 'width:100%;height:100%;border:0;';
      btn.replaceWith(iframe);
    });
  }
</script>
