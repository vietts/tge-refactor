---
interface Fact {
  label: string;
  value: string;
  sub?: string;
  icon: 'calendar' | 'pin' | 'loop' | 'road' | 'clock' | 'mountain';
}
interface Props {
  facts: Fact[];
  accentColor?: string;
  textColor?: string;
}
const { facts, accentColor, textColor } = Astro.props;

// Auto-pick readable text color when not overridden.
// Parses 3- or 6-digit hex and uses YIQ luminance; defaults to --espresso.
function pickTextColor(hex?: string): string | undefined {
  if (!hex) return undefined;
  const h = hex.replace('#', '');
  const full = h.length === 3 ? h.split('').map((c) => c + c).join('') : h;
  if (full.length !== 6) return undefined;
  const r = parseInt(full.slice(0, 2), 16);
  const g = parseInt(full.slice(2, 4), 16);
  const b = parseInt(full.slice(4, 6), 16);
  const yiq = (r * 299 + g * 587 + b * 114) / 1000;
  return yiq >= 165 ? '#2C1F15' : '#F3ECE0';
}
const resolvedText = textColor ?? pickTextColor(accentColor);
const styleAttr = [
  accentColor ? `--accent:${accentColor}` : '',
  resolvedText ? `--facts-text:${resolvedText}` : '',
].filter(Boolean).join(';');
---
<section class="facts" style={styleAttr || undefined}>
  <div class="facts-grid">
    {facts.map((f) => (
      <div class="fact sr">
        <div class="fact-head">
        <div class="fact-icon" aria-hidden="true">
          {f.icon === 'calendar' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18"/><path d="M8 3v4"/><path d="M16 3v4"/></svg>
          )}
          {f.icon === 'pin' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-7.5 8-13a8 8 0 1 0-16 0c0 5.5 8 13 8 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
          )}
          {f.icon === 'loop' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7"/><polyline points="21 3 21 9 15 9"/></svg>
          )}
          {f.icon === 'road' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21 9 3"/><path d="M20 21 15 3"/><path d="M12 7v1"/><path d="M12 12v1"/><path d="M12 17v1"/></svg>
          )}
          {f.icon === 'clock' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
          )}
          {f.icon === 'mountain' && (
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20 10 8l4 7 3-4 4 9z"/></svg>
          )}
        </div>
        <div class="fact-label">{f.label}</div>
        </div>
        <div class="fact-body">
          <div class="fact-value">{f.value}</div>
          {f.sub && <div class="fact-sub">{f.sub}</div>}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .facts {
    background: var(--accent, var(--caramel));
    color: var(--facts-text, var(--espresso));
    padding: var(--sp-6) var(--sp-5);
    position: relative;
    border-top: 1px solid rgba(44,31,21,0.1);
    border-bottom: 1px solid rgba(44,31,21,0.1);
  }
  .facts-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0;
    max-width: 1100px; margin: 0 auto;
  }
  /* Mobile: horizontal row — icon+label left, value+sub right — equal weight per row */
  .fact {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(44,31,21,0.12);
  }
  .fact:last-child { border-bottom: 0; }
  .fact-head { display: flex; align-items: center; gap: 0.55rem; }
  .fact-body { min-width: 0; }

  .fact-icon {
    width: 22px; height: 22px;
    color: var(--facts-text, var(--espresso));
    opacity: 0.85;
    flex-shrink: 0;
  }
  .fact-icon svg { width: 100%; height: 100%; }
  .fact-label {
    font-family: var(--font-display); font-weight: 700;
    font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--facts-text, var(--espresso)); opacity: 0.7;
  }
  .fact-value {
    font-family: var(--font-display); font-weight: 800;
    font-size: 1rem; line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--facts-text, var(--espresso));
    text-transform: uppercase;
  }
  .fact-sub {
    font-family: var(--font-body);
    font-size: 0.78rem; line-height: 1.3;
    color: var(--facts-text, var(--espresso)); opacity: 0.7;
    margin-top: 0.15rem;
  }

  /* Desktop: 4-column vertical cards — icon on top, label, value, sub */
  @media (min-width: 720px) {
    .facts { padding: var(--sp-7) var(--sp-5); }
    .facts-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 2rem 1.5rem; }
    .fact {
      display: flex; flex-direction: column; align-items: flex-start;
      gap: 0.5rem;
      padding: 0;
      border-bottom: 0;
    }
    .fact-head { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .fact-icon { width: 40px; height: 40px; }
    .fact-label { font-size: 0.68rem; letter-spacing: 0.22em; opacity: 0.65; }
    .fact-value { font-size: 1.55rem; }
    .fact-sub { font-size: 0.82rem; margin-top: 0; }
  }
</style>
