---
interface Props {
  label: string;
  partners: Array<{ name: string; logo: string; isMain?: boolean }>;
}
const { label, partners } = Astro.props;
const main = partners.filter((p) => p.isMain);
const others = partners.filter((p) => !p.isMain);
---
<section class="trust">
  <div class="container">
    <div class="kicker trust-label">{label}</div>

    {main.length > 0 && (
      <div class="trust-main sr">
        {main.map((p) => (
          <a href="https://www.bikeadventureseries.com" target="_blank" rel="noopener" class="trust-main-link">
            <img src={p.logo} alt={p.name} loading="lazy" />
          </a>
        ))}
      </div>
    )}

    {others.length > 0 && (
      <>
        <div class="kicker trust-sub sr">Supported by</div>
        <div class="trust-logos sr d1">
          {others.map((p) => (
            <div class="trust-logo">
              <img src={p.logo} alt={p.name} loading="lazy" />
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>

<style>
  .trust {
    background: var(--navy); color: #fff;
    padding: var(--sp-8) 0;
    text-align: center;
  }
  .trust-label { opacity: 0.65; margin-bottom: 1.25rem; }

  .trust-main { margin-bottom: 2.5rem; }
  .trust-main-link { display: inline-flex; align-items: center; justify-content: center; }
  .trust-main img {
    height: 72px; width: auto; max-width: 300px;
    opacity: 0.95;
    transition: opacity 160ms;
  }
  .trust-main-link:hover img { opacity: 1; }

  .trust-sub { opacity: 0.5; margin-bottom: 1rem; font-size: 0.7rem; }

  .trust-logos {
    display: flex; flex-wrap: wrap; justify-content: center; align-items: center;
    gap: 2rem 2.5rem;
    max-width: 900px; margin: 0 auto;
  }
  .trust-logo img {
    height: 36px; width: auto; max-width: 140px;
    opacity: 0.9;
    transition: opacity 160ms;
  }
  .trust-logo:hover img { opacity: 1; }

  @media (min-width: 720px) {
    .trust-main img { height: 96px; max-width: 360px; }
    .trust-logo img { height: 44px; }
  }
</style>
