---
const pixelId = import.meta.env.PUBLIC_META_PIXEL_ID;
---
{pixelId && (
  <script is:inline define:vars={{ pixelId }}>
    // Standard Meta Pixel base — kept inert until consent is granted.
    !(function (f, b, e, v, n, t, s) {
      if (f.fbq) return;
      n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
      if (!f._fbq) f._fbq = n;
      n.push = n; n.loaded = !0; n.version = '2.0'; n.queue = [];
      t = b.createElement(e); t.async = !0;
      t.src = 'https://connect.facebook.net/en_US/fbevents.js';
      s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
    })(window, document, 'script');

    function tgeInitPixel() {
      if (window._tgePixelInited) return;
      window.fbq('init', pixelId);
      window.fbq('track', 'PageView');
      window._tgePixelInited = true;
    }
    function tgeCheckConsent() {
      try {
        const c = JSON.parse(localStorage.getItem('tge_consent') || 'null');
        if (c && c.marketing) tgeInitPixel();
      } catch {}
    }
    tgeCheckConsent();
    window.addEventListener('tge:consent-change', tgeCheckConsent);

    // Handy helper used by BrevoForm and the WhatsApp badge.
    window.tgeTrack = function (eventName, params, options) {
      if (window._tgePixelInited && window.fbq) {
        window.fbq('track', eventName, params || {}, options || {});
      }
    };
  </script>
  <noscript>
    <img height="1" width="1" style="display:none" alt=""
      src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`} />
  </noscript>
)}
