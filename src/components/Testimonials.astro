---
import Icon from './Icon.astro';

interface Testimonial {
  quote: string;
  author: string;
  role?: string;
  event?: string;
}

interface Props {
  kicker: string;
  title: string;
  items: Testimonial[];
}
const { kicker, title, items } = Astro.props;
---
<section class="testimonials">
  <div class="container testimonials-head sr">
    <div class="kicker">{kicker}</div>
    <h2 class="testimonials-title display">{title}</h2>
  </div>

  <div class="testimonials-scroll" role="list">
    {items.map((t) => (
      <figure class="quote-card" role="listitem">
        <blockquote class="quote-body serif">
          <span aria-hidden="true" class="quote-mark">"</span>
          {t.quote}
        </blockquote>
        <figcaption class="quote-attr">
          <span class="quote-author">{t.author}</span>
          {t.event && <span class="quote-event">{t.event}</span>}
        </figcaption>
      </figure>
    ))}
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span>Swipe</span>
    <span class="arrow"><Icon name="arrow" size={14} /></span>
  </div>
</section>

<style>
  .testimonials {
    padding: var(--sp-8) 0;
    overflow: hidden;
    position: relative;
  }
  .testimonials-head {
    padding: 0 var(--sp-5);
    max-width: var(--container);
    margin: 0 auto 2rem;
  }
  .testimonials-head .kicker { color: var(--fern); margin-bottom: 0.75rem; }
  .testimonials-title {
    font-size: var(--fs-3xl); line-height: 0.95;
    color: var(--red-wine);
  }

  .testimonials-scroll {
    display: flex; gap: 1rem;
    padding: 0 var(--sp-5) 1rem;
    overflow-x: auto; overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scroll-padding: var(--sp-5);
  }
  .testimonials-scroll::-webkit-scrollbar { height: 6px; }
  .testimonials-scroll::-webkit-scrollbar-track { background: transparent; }
  .testimonials-scroll::-webkit-scrollbar-thumb { background: rgba(29,59,95,0.2); border-radius: 3px; }

  .quote-card {
    flex: 0 0 85%;
    max-width: 360px;
    background: rgba(255,255,255,0.55);
    backdrop-filter: blur(6px);
    padding: 2rem 1.5rem 1.5rem;
    border-radius: 12px;
    border: 1px solid rgba(107,68,35,0.14);
    scroll-snap-align: start;
    display: flex; flex-direction: column; gap: 1.25rem;
    box-shadow: 0 4px 20px rgba(44,31,21,0.06);
  }
  .quote-body {
    position: relative;
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--espresso);
    padding-top: 0.5rem;
  }
  .quote-mark {
    font-family: Georgia, serif;
    font-size: 4rem;
    line-height: 0.4;
    color: var(--red-wine);
    opacity: 0.35;
    position: absolute;
    top: 0; left: -0.2rem;
  }
  .quote-attr {
    display: flex; flex-direction: column;
    font-size: 0.78rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(107,68,35,0.18);
  }
  .quote-author {
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--red-wine);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .quote-event {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--navy);
    opacity: 0.85;
    margin-top: 0.15rem;
  }

  .scroll-hint {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0 var(--sp-5);
    max-width: var(--container);
    margin: 0 auto;
    font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;
    opacity: 0.45;
    font-weight: 700;
  }
  .scroll-hint .arrow {
    animation: drift 1.6s ease-in-out infinite;
  }
  @keyframes drift {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(6px); }
  }

  @media (min-width: 900px) {
    .testimonials-scroll {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
      max-width: var(--container);
      margin: 0 auto;
      overflow: visible;
      padding: 0 var(--sp-5);
    }
    .quote-card { flex: initial; max-width: none; }
    .scroll-hint { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-hint .arrow { animation: none; }
  }
</style>
