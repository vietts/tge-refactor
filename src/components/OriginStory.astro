---
interface Props {
  kicker: string;
  imageCaption: string;
  title: string;
  body: string[];
  imageBg?: string;
  image?: string;
}
const { kicker, imageCaption, title, body, imageBg, image } = Astro.props;
const bg = image ? `url('${image}') center/cover no-repeat` : (imageBg ?? 'radial-gradient(ellipse at 30% 40%, #d48a42 0%, transparent 60%), linear-gradient(180deg, #6b4228 0%, #2e1808 100%)');
---
<section class="origin">
  <div class="origin-image sr" style={`background:${bg}`}>
    <p class="origin-caption serif">"{imageCaption}"</p>
  </div>
  <div class="origin-body sr d1">
    <div class="container-narrow">
      <div class="kicker origin-kicker">{kicker}</div>
      <h2 class="origin-title display">{title}</h2>
      {body.map((p, i) => <p class:list={['origin-p', { muted: i === body.length - 1 && body.length > 1 }]}>{p}</p>)}
    </div>
  </div>
</section>

<style>
  .origin { position: relative; }
  .origin-image {
    position: relative; min-height: 260px; aspect-ratio: 16/10;
    background-size: cover; background-position: center;
    display: flex; align-items: flex-end; padding: 1.5rem;
  }
  .origin-image::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.55) 100%);
  }
  .origin-caption { position: relative; font-family: var(--font-body); font-style: italic; font-size: var(--fs-lg); line-height: 1.3; color: var(--paper-1); max-width: 22ch; }

  .origin-body { padding: var(--sp-8) 0; }
  .origin-kicker { color: var(--fern); margin-bottom: 0.6rem; }
  .origin-title { font-size: var(--fs-3xl); line-height: 0.95; color: var(--red-wine); margin-bottom: 1rem; }
  .origin-p { font-family: var(--font-body); font-size: 1rem; line-height: 1.65; margin-bottom: 0.75rem; color: var(--espresso); }
  .origin-p.muted { opacity: 0.65; font-size: 0.9rem; color: var(--coffee); letter-spacing: 0.02em; }

  @media (min-width: 900px) {
    .origin { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
    .origin-image { min-height: 480px; aspect-ratio: auto; }
    .origin-body { display: flex; flex-direction: column; justify-content: center; padding: var(--sp-8) var(--sp-7); }
  }
</style>
